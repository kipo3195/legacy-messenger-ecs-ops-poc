{
  "family": "fetch-task",
  "networkMode": "bridge",
  "requiresCompatibilities": [
    "EC2"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::메타데이터:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "fetch",
      "image": "메타데이터.dkr.ecr.ap-northeast-2.amazonaws.com/fetch:0.1.0",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 33007,
          "hostPort": 33007,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "command": [
        "ws",
        "FETCH",
        "33007"
      ],
      "environment": [
        {
          "name": "CONFIG_PATH",
          "value": "/config/dbconfig.ini"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "config-volume",
          "containerPath": "/config",
          "readOnly": true
        }
      ],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/fetch",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "systemControls": []
    }
  ],
  "volumes": [
    {
      "name": "config-volume",
      "host": {
        "sourcePath": "/home/ws/config"
      }
    }
  ],
  "placementConstraints": []
}
