{
  "family": "ws-task",
  "networkMode": "bridge",
  "requiresCompatibilities": [
    "EC2"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::메타데이터:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "ws",
      "image": "메타데이터.dkr.ecr.ap-northeast-2.amazonaws.com/ws:0.1.0",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 33002,
          "hostPort": 0,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "command": [
        "ws",
        "WS",
        "33002"
      ],
      "environment": [],
      "mountPoints": [
        {
          "sourceVolume": "config",
          "containerPath": "/config",
          "readOnly": true
        },
        {
          "sourceVolume": "security-key-volume",
          "containerPath": "/security_key",
          "readOnly": true
        }
      ],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ws",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "systemControls": []
    }
  ],
  "volumes": [
    {
      "name": "config",
      "host": {
        "sourcePath": "/home/ws/config"
      }
    },
    {
      "name": "security-key-volume",
      "host": {
        "sourcePath": "/home/ws/security_key"
      }
    }
  ],
  "placementConstraints": []
}
